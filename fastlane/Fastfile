require "dotenv"

Dotenv.load(File.join(__dir__, ".env.local"), File.join(__dir__, ".env.default"))

default_platform(:ios)

PROJECT = "Poch1441.xcodeproj"
SCHEME = "Poch1441"
INTERNAL_QA_SCHEME = "Poch1441InternalQA"
ARCHIVE_PATH = "build/Poch1441.xcarchive"
INTERNAL_QA_ARCHIVE_PATH = "build/Poch1441InternalQA.xcarchive"
OUTPUT_DIRECTORY = "build"
PROJECT_ROOT = File.expand_path("..", __dir__)

def asc_api_key
  key_id = ENV.fetch("ASC_KEY_ID")
  issuer_id = ENV.fetch("ASC_ISSUER_ID")
  key_filepath = File.expand_path(ENV.fetch("ASC_KEY_PATH"))

  UI.user_error!("App Store Connect key file missing: #{key_filepath}") unless File.exist?(key_filepath)

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_filepath,
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  private_lane :build_release_archive do |options|
    setup_ci if ENV["CI"]

    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      archive_path: ARCHIVE_PATH,
      output_directory: OUTPUT_DIRECTORY,
      output_name: "Poch1441.ipa",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV.fetch("APPLE_TEAM_ID", "GWP236628H"),
        manageAppVersionAndBuildNumber: true
      },
      include_symbols: true,
      skip_package_ipa: options.fetch(:skip_package_ipa, false)
    )
  end

  private_lane :build_internal_qa_archive do |options|
    setup_ci if ENV["CI"]

    gym(
      project: PROJECT,
      scheme: INTERNAL_QA_SCHEME,
      configuration: "InternalQA",
      clean: true,
      archive_path: INTERNAL_QA_ARCHIVE_PATH,
      output_directory: OUTPUT_DIRECTORY,
      output_name: "Poch1441InternalQA.ipa",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{options.fetch(:build_number)}",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV.fetch("APPLE_TEAM_ID", "GWP236628H"),
        manageAppVersionAndBuildNumber: false,
        testFlightInternalTestingOnly: true
      },
      include_symbols: true
    )
  end

  desc "Build a local Release archive without uploading"
  lane :archive_only do
    build_release_archive(skip_package_ipa: true)
  end

  desc "Archive and immediately upload the current build to TestFlight"
  lane :archive do
    api_key = asc_api_key

    next_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_IDENTIFIER", "com.tobc.poch1441"),
      initial_build_number: 0
    ) + 1
    increment_build_number(
      build_number: next_build_number,
      xcodeproj: PROJECT
    )

    build_release_archive(skip_package_ipa: false)

    upload_to_testflight(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_IDENTIFIER", "com.tobc.poch1441"),
      ipa: File.join(OUTPUT_DIRECTORY, "Poch1441.ipa"),
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      uses_non_exempt_encryption: false
    )
  end

  desc "Build and optionally upload the internal product and hardware QA candidate"
  lane :internal_coin_qa do |options|
    api_key = asc_api_key
    app_identifier = ENV.fetch("APP_IDENTIFIER", "com.tobc.poch1441")
    should_upload = options.fetch(:upload, true).to_s != "false"
    next_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: app_identifier,
      initial_build_number: 0
    ) + 1

    build_internal_qa_archive(build_number: next_build_number)

    archived_app = File.join(
      PROJECT_ROOT,
      INTERNAL_QA_ARCHIVE_PATH,
      "Products/Applications/Poch1441.app"
    )
    archived_binary = File.join(archived_app, "Poch1441")
    linked_libraries = sh("xcrun otool -L #{archived_binary}", log: false)
    UI.user_error!("InternalQA archive links DeveloperToolsSupport") if linked_libraries.include?("DeveloperToolsSupport")

    debug_dylibs = Dir.glob(File.join(archived_app, "*debug*.dylib"))
    UI.user_error!("InternalQA archive contains a debug dylib: #{debug_dylibs.join(', ')}") unless debug_dylibs.empty?

    if should_upload
      upload_to_testflight(
        api_key: api_key,
        app_identifier: app_identifier,
        ipa: File.join(OUTPUT_DIRECTORY, "Poch1441InternalQA.ipa"),
        skip_waiting_for_build_processing: false,
        distribute_external: false,
        uses_non_exempt_encryption: false,
        changelog: "Interner kabelloser Produktcheck: neuer spielnaher Vorscreen, interaktive Zeitreise von 1441 bis heute, überarbeitete Tutorial-Regie, organisch verteilte Karten sowie neue Münz-, Klang- und Kontaktabstimmung. Bitte Einstieg, Wischrichtung, Lesbarkeit und erste komplette Runde prüfen. Kein Produktionskandidat."
      )
    else
      UI.success("InternalQA archive and IPA are ready; TestFlight upload was intentionally skipped.")
    end
  end

  desc "Finish internal distribution for an already uploaded QA build"
  lane :distribute_internal_qa_existing do |options|
    api_key = asc_api_key

    upload_to_testflight(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_IDENTIFIER", "com.tobc.poch1441"),
      app_platform: "ios",
      distribute_only: true,
      app_version: "0.1.0",
      build_number: options.fetch(:build_number).to_s,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      uses_non_exempt_encryption: false,
      changelog: "Interner kabelloser Produktcheck: neuer spielnaher Vorscreen, interaktive Zeitreise von 1441 bis heute, überarbeitete Tutorial-Regie, organisch verteilte Karten sowie neue Münz-, Klang- und Kontaktabstimmung. Bitte Einstieg, Wischrichtung, Lesbarkeit und erste komplette Runde prüfen. Kein Produktionskandidat."
    )
  end

  desc "Alias for archive and TestFlight upload"
  lane :beta do
    archive
  end
end
