    "tutorial.bidding.reply.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitgehen kostet %d. Passen schützt deine Chips; erhöhen baut Druck auf."
