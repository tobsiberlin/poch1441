    "firstRun.cinematic.accessibility.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Hana spielt die erste Runde mit dir. Bestimmte Trumpfkarten gewinnen Bonus-Töpfe, gleiche Karten öffnen das Pochen und die letzte Karte gewinnt die Mitte." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hana plays the first round with you. Certain trump cards win bonus pots, matching cards open the bidding, and the last card wins the centre." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Hana juega la primera ronda contigo. Algunas cartas de triunfo ganan botes extra, las cartas iguales abren la puja y la última carta gana el centro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Hana joue la première manche avec toi. Certaines cartes d'atout gagnent des pots bonus, les cartes identiques ouvrent les enchères et la dernière carte remporte le centre." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Hana gioca la prima partita con te. Alcune carte di briscola vincono i piatti bonus, le carte uguali aprono l'offerta e l'ultima carta vince il centro." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Hana speelt de eerste ronde met je. Bepaalde troefkaarten winnen bonuspotten, gelijke kaarten openen het bieden en de laatste kaart wint het midden." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Hana rozgrywa z tobą pierwszą rundę. Wybrane atuty wygrywają pule bonusowe, jednakowe karty otwierają licytację, a ostatnia karta wygrywa środek." } }
      }
    },
    "firstRun.cinematic.accessibility.people" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah und Jonas sitzen am Tisch. Hana lädt dich zur ersten Runde ein." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah and Jonas are seated at the table. Hana invites you to join the first round." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah y Jonas están sentados a la mesa. Hana te invita a la primera ronda." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah et Jonas sont à table. Hana t'invite à la première manche." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah e Jonas sono al tavolo. Hana ti invita alla prima partita." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah en Jonas zitten aan tafel. Hana nodigt je uit voor de eerste ronde." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Hana, Noah i Jonas siedzą przy stole. Hana zaprasza cię do pierwszej rundy." } }
