    "phase3.guided.first.detail" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ eröffnet die Reihe. Danach geht dieselbe Farbe Karte für Karte aufwärts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ opens the run. Then the same suit climbs one card at a time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ abre la serie. Después, el mismo palo sube carta a carta."
