    "phase3.final.you.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du nimmst die Mitte. Jeder Gegner zahlt dir 1 Chip pro Restkarte - solange sein Vorrat reicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You take the centre. Each opponent pays you 1 chip per remaining card - while their supply lasts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te llevas el centro. Cada rival te paga 1 ficha por carta restante, mientras le queden fichas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous prenez le centre. Chaque adversaire paie 1 jeton par carte restante, tant qu'il lui en reste."
