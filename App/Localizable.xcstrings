        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empiezas a jugar de inmediato. Hana explica solo la decisión que importa ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous jouez immédiatement. Hana n'explique que la décision qui compte maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inizi subito a giocare. Hana spiega solo la decisione che conta adesso."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je speelt meteen. Hana legt alleen de beslissing uit die nu telt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Od razu zaczynasz grać. Hana wyjaśnia tylko decyzję, która liczy się teraz."
