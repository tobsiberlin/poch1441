    "firstRun.cinematic.bidding.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur ihr zwei seid noch drin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only two of you remain."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo quedáis dos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n'êtes plus que deux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siete rimasti in due."
          }
        },
        "nl" : {
          "stringUnit" : {
