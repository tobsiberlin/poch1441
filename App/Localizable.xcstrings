    "tutorial.meld.connect.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der König-Topf gehört dem König in Trumpf. Du hältst ihn - melde ihn jetzt. Er bleibt in deiner Hand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the marked King. It stays in your hand and immediately wins the King pot."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca el Rey marcado. Permanece en tu mano y gana inmediatamente el bote del Rey."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur le Roi marqué. Il reste dans votre main et gagne immédiatement le pot du Roi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca il Re segnato. Rimane nella tua mano e vince immediatamente il piatto del Re."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik op de gemarkeerde Koning. Hij blijft in je hand en wint direct de Koning-pot."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dotknij zaznaczonego Króla. Pozostaje w twojej ręce i natychmiast wygrywa pulę Króla."
          }
        }
      }
    },
