    "firstRun.intro.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mira zeigt dir immer nur den nächsten Zug. Du spielst sofort selbst." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Mira shows you only the next move. You play for yourself from the start." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Mira te muestra solo el siguiente movimiento. Tú juegas desde el principio." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Mira vous montre uniquement le prochain coup. Vous jouez vous-même dès le début." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Mira ti mostra solo la prossima mossa. Giochi tu fin dall'inizio." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Mira toont alleen de volgende zet. Je speelt vanaf het begin zelf." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Mira pokazuje tylko następny ruch. Od początku grasz samodzielnie." } }
      }
    },
    "firstRun.goal" : {
