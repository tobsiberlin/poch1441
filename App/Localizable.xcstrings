    "tutorial.bidding.uncontested.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle anderen passen. Bleiben mehrere dabei, entscheidet die stärkste Kartenkombination."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Everyone else folds. If several remain, the strongest card combination decides."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los demás pasan. Si quedan varios, la combinación de cartas más fuerte decide."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tous les autres passent. S'il en reste plusieurs, la combinaison de cartes la plus forte décide."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutti gli altri passano. Se ne rimangono diversi, la combinazione di carte più forte decide."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle anderen passen. Blijven er meerdere over, dan beslist de sterkste kaartencombinatie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszyscy inni pasują. Jeśli pozostanie ich kilka, decyduje najsilniejsza kombinacja kart."
          }
        }
      }
    },
    "tutorial.bidding.uncontested.title" : {
