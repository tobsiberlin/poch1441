    "tutorial.bidding.noPair.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur mit mindestens einem Paar darfst du pochen. Diesmal passt du und setzt nichts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You may only bid with at least one pair. This time you fold and bet nothing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo puedes pujar con al menos un par. Esta vez pasas y no apuestas nada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ne pouvez miser qu'avec au moins une paire. Cette fois, vous passez et ne misez rien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi fare un'offerta solo con almeno un paio. Questa volta passi e non scommetti nulla."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alleen met minstens één paar mag je bieden. Dit keer pas je en zet je niets in."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz licytować tylko z przynajmniej jedną parą. Tym razem pasujesz i nie stawiasz nic."
          }
        }
      }
    },
