    "firstRun.timeSwipe.prelude.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Räum mit Trumpf ab, poch um den Einsatz und werde deine Karten zuerst los." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Claim bonus pots with trump, challenge the table for the stake, and shed your cards first." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Gana botes extra con el triunfo, desafía a la mesa por la apuesta y sé el primero en quedarte sin cartas." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Rafle les pots bonus avec l’atout, défie la table pour la mise et vide ta main en premier." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Conquista i piatti bonus con la briscola, sfida il tavolo per la posta e svuota la mano per primo." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Pak bonuspotten met troef, daag de tafel uit om de inzet en speel als eerste je hand leeg." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Zgarniaj pule bonusowe atutami, rzuć wyzwanie o stawkę i jako pierwszy pozbądź się kart." } }
      }
    },
    "firstRun.timeSwipe.prelude.eyebrow" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "EINE RUNDE, DREI CHANCEN" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "ONE ROUND, THREE CHANCES" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "UNA RONDA, TRES OPORTUNIDADES" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "UNE MANCHE, TROIS CHANCES" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "UNA MANO, TRE OCCASIONI" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "ÉÉN RONDE, DRIE KANSEN" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "JEDNA RUNDA, TRZY SZANSE" } }
      }
    },
    "firstRun.timeSwipe.prelude.primary" : {
      "extractionState" : "manual",
