    "tutorial.bidding.commit.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit %d Chips forderst du den Tisch heraus. Die anderen können mitgehen, erhöhen oder passen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap 'Bid for %d chip'. Anyone with at least one pair can call, raise, or fold."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca 'Pujar por %d ficha'. Quien tenga al menos un par puede igualar, subir o pasar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur « Miser pour %d jeton ». Quiconque possède au moins une paire peut suivre, relancer ou passer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca 'Offri per %d fiche'. Chiunque abbia almeno un paio può chiamare, rilanciare o passare."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik op 'Bieden voor %d chip'. Wie minstens één paar heeft, kan meegaan, verhogen of passen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dotknij 'Licytuj za %d żeton'. Kto ma przynajmniej jedną parę, może sprawdzić, podbić lub spasować."
          }
        }
      }
    },
