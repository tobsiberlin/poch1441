    "firstRun.cinematic.bidding.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Einsatz hält euch im Spiel. Gleich zeigen eure Karten, wer den Poch nimmt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The stake keeps you in. Your cards will show who takes the Poch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La apuesta os mantiene dentro. Las cartas dirán quién se lleva el Poch."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mise vous garde en jeu. Vos cartes diront qui remporte le Poch."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La puntata vi tiene in gioco. Le carte diranno chi prende il Poch."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De inzet houdt jullie in het spel. De kaarten bepalen wie de Poch pakt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stawka utrzymuje was w grze. Karty pokażą, kto zgarnie Poch."
          }
        }
      }
    },
