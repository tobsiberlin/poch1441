        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lleva ese impulso a la mesa libre - o repite la jugada una vez más."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez cet élan pour la table libre - ou rejouez ce coup une fois encore."
