            "state" : "translated",
            "value" : "Straks toont de open tafelkaart welke kleur troef is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wkrótce otwarta karta stołu pokaże, który kolor jest atutowy."
          }
        }
      }
    },
