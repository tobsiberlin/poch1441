    "firstRun.timeSwipe.origin.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Pokers älterer Bruder. Seit 1441." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Poker’s older brother. Since 1441." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El hermano mayor del póker. Desde 1441." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le grand frère du poker. Depuis 1441." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il fratello maggiore del poker. Dal 1441." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Pokers oudere broer. Sinds 1441." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Starszy brat pokera. Od 1441 roku." } }
      }
    },
