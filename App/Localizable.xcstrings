    "opponent.tendency.measuredPace.summary" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Nimmt sich bei Entscheidungen meist etwas mehr Zeit." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Usually takes a little more time over decisions." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Suele tomarse algo más de tiempo para decidir." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Prend généralement un peu plus de temps pour décider." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Di solito si prende un po’ più di tempo per decidere." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Neemt meestal wat meer tijd voor beslissingen." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Zwykle poświęca decyzjom trochę więcej czasu." } }
      }
    },
