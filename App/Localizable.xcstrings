    "phase3.final.opponent.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nimmt die Mitte. Du zahlst 1 Chip pro Restkarte - solange dein Vorrat reicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ takes the centre. You pay 1 chip per remaining card - while your supply lasts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ se lleva el centro. Pagas 1 ficha por carta restante, mientras te queden fichas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ prend le centre. Vous payez 1 jeton par carte restante, tant qu'il vous en reste."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ prende il centro. Paghi 1 fiche per carta rimasta, finché ne hai."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ pakt het midden. Je betaalt 1 fiche per restkaart, zolang je voorraad strekt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ zabiera środek. Płacisz 1 żeton za każdą pozostałą kartę, dopóki masz żetony."
          }
        }
      }
    },
