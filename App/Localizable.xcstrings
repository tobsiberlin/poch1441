    "tutorial.guide.finish.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Sieger nimmt die Mitte. Jeder Gegner zahlt 1 Chip pro Restkarte - solange sein Vorrat reicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The winner takes the centre. Each opponent pays 1 chip per remaining card - while their supply lasts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El ganador se lleva el centro. Cada rival paga 1 ficha por carta restante, mientras le queden fichas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le gagnant prend le centre. Chaque adversaire paie 1 jeton par carte restante, tant qu'il lui en reste."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il vincitore prende il centro. Ogni avversario paga 1 fiche per carta rimasta, finché ne ha."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De winnaar pakt het midden. Elke tegenstander betaalt 1 fiche per restkaart, zolang de voorraad strekt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwycięzca zabiera środek. Każdy przeciwnik płaci 1 żeton za pozostałą kartę, dopóki ma żetony."
          }
        }
      }
    },
