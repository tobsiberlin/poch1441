    "firstRun.timeSwipe.takeSeat" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "An den Tisch" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Take your seat" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "A la mesa" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "À table" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Al tavolo" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Aan tafel" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Do stołu" } }
      }
    },
    "firstRun.timeSwipe.today.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die richtigen Trumpfkarten räumen Bonus-Töpfe ab. Beim Pochen riskierst du Chips. Wer zuerst alle Karten los ist, holt das Finale." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The right trump cards claim bonus pots. When you poch, you put chips on the line. First to shed every card wins the finale." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Los triunfos adecuados se llevan los botes extra. Al pochar arriesgas fichas. Quien se quede primero sin cartas gana el final." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les bons atouts raflent les pots bonus. En pochant, tu mets des jetons en jeu. Le premier à vider sa main remporte le final." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Le briscole giuste conquistano i piatti bonus. Quando pochen rischi le fiches. Chi svuota per primo la mano vince il finale." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "De juiste troefkaarten pakken bonuspotten. Bij het pochen riskeer je fiches. Wie als eerste alle kaarten kwijt is, wint de finale." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Właściwe atuty zgarniają pule bonusowe. Podczas pochen ryzykujesz żetony. Kto pierwszy pozbędzie się kart, wygrywa finał." } }
      }
    },
    "firstRun.timeSwipe.today.eyebrow" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "HEUTE" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "TODAY" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "HOY" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "AUJOURD’HUI" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "OGGI" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "VANDAAG" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "DZISIAJ" } }
      }
    },
    "firstRun.timeSwipe.today.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Drei Chancen. Eine Runde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Three chances. One round." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tres oportunidades. Una ronda." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Trois chances. Une manche." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tre occasioni. Un solo giro." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Drie kansen. Eén ronde." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Trzy szanse. Jedna runda." } }
      }
    },
    "firstRun.timeSwipe.withoutGuide" : {
