    "tutorial.guide.deal.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schon %d von %d Karten verteilt. Jede Karte bleibt sichtbar bei ihrem Spieler."
          }
        },
        "en" : {
          "stringUnit" : {
