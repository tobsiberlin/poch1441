    "tutorial.guide.trump.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decke die Tischkarte auf. Sie bestimmt nur die Trumpffarbe und gehört zu keiner Hand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reveal the table card. It only determines the trump suit and does not belong to any hand."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revela la carta de la mesa. Solo determina el palo de triunfo y no pertenece a ninguna mano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Révélez la carte de la table. Elle ne détermine que la couleur d'atout et n'appartient à aucune main."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rivela la carta del tavolo. Determina solo il seme di briscola e non appartiene a nessuna mano."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ontdek de tafelkaart. Deze bepaalt alleen de troefkleur en behoort niet tot een hand."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odkryj kartę stołu. Określa ona tylko kolor atutowy i nie należy do żadnej ręki."
          }
        }
      }
    },
