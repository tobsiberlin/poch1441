    "tutorial.meld.ante.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Chip wandert nacheinander in jeden Topf. So siehst du genau, wo der Einsatz landet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seven bonus pots pay out immediately for matching trump cards. The Poch pot will be bid for next. The center counts at the end."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siete botes de bonificación pagan inmediatamente por las cartas de triunfo coincidentes. Por el bote de Poch se pujará a continuación. El centro cuenta al final."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sept pots bonus rapportent immédiatement pour les cartes d'atout correspondantes. Le pot de Poch sera mis aux enchères ensuite. Le centre compte à la fin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sette piatti bonus pagano immediatamente per le briscole corrispondenti. Per il piatto di Poch si farà un'offerta subito dopo. Il centro conta alla fine."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeven bonuspotten betalen direct uit voor passende troefkaarten. Om de Poch-pot wordt straks geboden. Het midden telt aan het eind."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siedem pul bonusowych wypłaca się natychmiast za pasujące karty atutowe. O pulę Poch będzie licytacja. Środek liczy się na końcu."
          }
        }
      }
    },
