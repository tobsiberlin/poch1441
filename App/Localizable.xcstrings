    "firstRun.goal" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trumpf holt Bonus-Töpfe. Mit mindestens einem Paar bietest du um den Poch-Topf. Die letzte Karte gewinnt die Mitte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trump cards win bonus pots. With at least one pair, you bid for the Poch pot. The last card wins the center."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los triunfos ganan botes de bonificación. Con al menos un par, pujas por el bote de Poch. La última carta gana el centro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les atouts remportent les pots bonus. Avec au moins une paire, vous misez pour le pot de Poch. La dernière carte gagne le centre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le briscole vincono i piatti bonus. Con almeno un paio, fai un'offerta per il piatto di Poch. L'ultima carta vince il centro."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Troefkaarten winnen bonuspotten. Met minstens één paar bied je voor de Poch-pot. De laatste kaart wint het midden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atuty zdobywają pule bonusowe. Z przynajmniej jedną parą licytujesz o pulę Poch. Ostatnia karta wygrywa środek."
