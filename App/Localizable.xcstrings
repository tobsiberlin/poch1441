    "phase3.start.detail" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe eine Karte in deiner Hand. Niedrig starten lässt mehr Folgekarten zu." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tap a card in your hand. Starting low leaves more follow-up cards available." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Toca una carta de tu mano. Empezar bajo deja más cartas de continuación." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Touchez une carte de votre main. Commencer bas laisse davantage de cartes à suivre." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tocca una carta nella tua mano. Partire basso lascia più carte successive." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Tik op een kaart in je hand. Laag beginnen laat meer vervolgkaarten over." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Dotknij karty w ręce. Niski start pozostawia więcej kart do kontynuacji." } }
