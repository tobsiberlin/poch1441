      }
    },
    "firstRun.timeSwipe.prelude.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ein Tisch. Drei Duelle." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "One table. Three contests." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Una mesa. Tres duelos." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Une table. Trois duels." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Un tavolo. Tre sfide." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Eén tafel. Drie duels." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Jeden stół. Trzy pojedynki." } }
      }
    },
    "firstRun.timeSwipe.origin.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Drei Phasen, drei Wege zum Gewinn - und eine Spur, die bis ins 15. Jahrhundert führt." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Three phases, three ways to win - and a trail reaching back to the 15th century." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tres fases, tres formas de ganar y una huella que se remonta al siglo XV." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Trois phases, trois façons de gagner - et une piste qui remonte au XVe siècle." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tre fasi, tre modi per vincere e una traccia che risale al XV secolo." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Drie fasen, drie manieren om te winnen - en een spoor dat teruggaat tot de 15e eeuw." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Trzy fazy, trzy drogi do zwycięstwa - i ślad sięgający XV wieku." } }
      }
    },
    "firstRun.timeSwipe.origin.eyebrow" : {
