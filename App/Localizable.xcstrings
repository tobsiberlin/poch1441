        "es" : { "stringUnit" : { "state" : "translated", "value" : "Sé el primero en quedarte sin cartas y gana el centro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Videz votre main en premier et remportez le centre." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Svuota per primo la mano e conquista il centro." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Speel als eerste je hand leeg en win het midden." } },
