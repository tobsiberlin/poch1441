    "tutorial.meld.claim.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der König-Topf zahlt sofort. Mit der Trumpf-Dame bildet dein König außerdem die Hochzeit, traditionell Mariage genannt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your trump King wins the King pot. With the trump Queen, it forms the Mariage – this bonus is also yours."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu rey de triunfo gana el bote del Rey. Con la reina de triunfo, forma el Mariage – este bono también es tuyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre roi d'atout gagne le pot du Roi. Avec la dame d'atout, il forme le Mariage – ce bonus est aussi le vôtre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo Re di briscola vince il piatto del Re. Con la Regina di briscola, forma il Mariage – anche questo bonus è tuo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je troef-Koning wint de Koning-pot. Met de troef-Dame vormt hij de Mariage – ook deze bonus is van jou."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twój król atutowy wygrywa pulę Króla. Z damą atutową tworzy Mariage – ten bonus również należy do ciebie."
          }
        }
      }
    },
    "tutorial.meld.claim.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
