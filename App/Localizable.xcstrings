    "tutorial.completion.lesson.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nimm den Schwung mit an den freien Tisch - oder spiel den Zug noch einmal."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take that momentum to the open table - or play the move once more."
