    "tutorial.bidding.commit.body.one" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mit 1 Chip forderst du den Tisch heraus. Die anderen können mitgehen, erhöhen oder passen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "With 1 chip, you challenge the table. The others can call, raise, or fold." } },
