        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Runde, drei Wege zu Chips. Hana spielt mit und zeigt dir, warum jeder Zug zählt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
