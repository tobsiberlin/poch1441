      }
    },
    "tutorial.meld.firstDeal.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gib einmal reihum. Jede Karte hat eine sichtbare Quelle und ein klares Ziel." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Deal once around. Every card has a visible source and a clear destination." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Reparte una vuelta. Cada carta tiene un origen visible y un destino claro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Distribuez un tour. Chaque carte a une source visible et une destination claire." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Distribuisci un giro. Ogni carta ha un'origine visibile e una meta chiara." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Deel één ronde. Elke kaart heeft een zichtbare bron en een duidelijk doel." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Rozdaj jedną kolejkę. Każda karta ma widoczne źródło i wyraźny cel." } }
      }
    },
    "tutorial.meld.hand.title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deine Hand" } },
