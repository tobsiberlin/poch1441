    "firstRun.goal" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Werde zuerst deine Karten los und gewinne die Mitte." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Be first to empty your hand and win the centre." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Sé el primero en quedarte sin cartas y gana el centro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Videz votre main en premier et remportez le centre." } },
