    },
    "firstRun.cinematic.bonus.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bestimmte Trumpfkarten holen sofort, was vor dir liegt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certain trump cards instantly claim what lies before you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciertos triunfos se llevan al instante lo que tienes delante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certains atouts ramassent aussitôt ce qui est devant vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
