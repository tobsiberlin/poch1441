    "firstRun.cinematic.opening.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder liegen gebliebene Chip macht die nächste Runde interessanter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every chip left behind makes the next round more interesting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada ficha que queda hace más interesante la siguiente ronda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque jeton qui reste rend la manche suivante plus intéressante."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ogni fiche rimasta rende più interessante la mano successiva."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
