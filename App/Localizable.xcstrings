        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tres actos, tres objetivos claros. Me quedo en la mesa hasta que sientas el ritmo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois actes, trois objectifs clairs. Je reste à table jusqu'à ce que vous trouviez le rythme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tre atti, tre obiettivi chiari. Resto al tavolo finché non senti il ritmo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
