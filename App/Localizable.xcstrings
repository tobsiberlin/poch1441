    "opponent.tendency.variablePace.summary" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Entscheidet mal zügig, mal mit etwas mehr Zeit." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sometimes decides quickly, sometimes takes a little longer." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "A veces decide rápido y otras se toma algo más de tiempo." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Décide parfois vite, parfois en prenant un peu plus de temps." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "A volte decide in fretta, altre si prende un po’ più di tempo." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Beslist soms snel en neemt soms wat meer tijd." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Czasem decyduje szybko, a czasem potrzebuje nieco więcej czasu." } }
