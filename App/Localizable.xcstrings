        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your meld has landed. The learning aids can now disappear." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu declaración ha llegado. Las ayudas ya pueden desaparecer." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ton annonce est arrivée. Les aides peuvent maintenant disparaître." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "La tua dichiarazione è arrivata. Gli aiuti possono ora scomparire." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je melding is aangekomen. De leerhulpen kunnen nu verdwijnen." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Twój meldunek dotarł. Wskazówki mogą teraz zniknąć." } }
      }
    },
    "tutorial.meld.table.title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dein erster Stein" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your first token" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu primera ficha" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ton premier jeton" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il tuo primo gettone" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je eerste steen" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Twój pierwszy żeton" } }
      }
    },
    "tutorial.meld.table.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Lege ihn in die Mitte. Sie wird am Ende der Runde gewonnen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Place it in the center. The center is won at the end of the round." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Colócala en el centro. El centro se gana al final de la ronda." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Place-le au centre. Le centre est remporté à la fin de la manche." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Mettilo al centro. Il centro si vince alla fine della mano." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Leg hem in het midden. Het midden wordt aan het einde van de ronde gewonnen." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Połóż go na środku. Środek wygrywa się na końcu rundy." } }
      }
    },
    "tutorial.meld.ante.title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dein Stein liegt" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your token has landed" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu ficha ha llegado" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ton jeton est posé" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il tuo gettone è arrivato" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je steen ligt" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Twój żeton wylądował" } }
      }
    },
    "tutorial.meld.ante.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Mitte enthält jetzt 1. Als Nächstes legt jeder einen Stein in jede Mulde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The centre now contains 1. Next, everyone places one token in every well." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El centro ahora contiene 1. Después, cada jugador pone una ficha en cada hueco." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le centre contient maintenant 1. Ensuite, chacun pose un jeton dans chaque coupelle." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il centro ora contiene 1. Poi, ognuno mette un gettone in ogni vaschetta." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Het midden bevat nu 1. Daarna legt iedereen één steen in elk vak." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Na środku jest teraz 1. Następnie każdy kładzie po jednym żetonie w każdym polu." } }
      }
    },
    "tutorial.meld.firstDeal.title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die erste Runde" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The first pass" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La primera vuelta" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le premier tour" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il primo giro" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "De eerste ronde" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Pierwsze rozdanie" } }
      }
    },
    "tutorial.meld.firstDeal.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gib einmal reihum. Jede Karte hat eine sichtbare Quelle und ein klares Ziel." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Deal once around. Every card has a visible source and a clear destination." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Reparte una vuelta. Cada carta tiene un origen visible y un destino claro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Distribuez un tour. Chaque carte a une source visible et une destination claire." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Distribuisci un giro. Ogni carta ha un'origine visibile e una meta chiara." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Deel één ronde. Elke kaart heeft een zichtbare bron en een duidelijk doel." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Rozdaj jedną kolejkę. Każda karta ma widoczne źródło i wyraźny cel." } }
      }
    },
    "tutorial.meld.hand.title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deine Hand" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your hand" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu mano" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Votre main" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "La tua mano" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je hand" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Twoja ręka" } }
      }
    },
    "tutorial.meld.hand.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Jetzt wird fertig gegeben. Danach siehst du deine vollständige Hand." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Now finish the deal. Then you will see your complete hand." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Completa el reparto. Después verás toda tu mano." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Terminez la distribution. Vous verrez ensuite votre main complète." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Completa la distribuzione. Poi vedrai tutta la tua mano." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Maak het delen af. Daarna zie je je volledige hand." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Dokończ rozdawanie. Potem zobaczysz całą swoją rękę." } }
      }
    },
    "tutorial.meld.claim.title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Meldung erkennen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Spot the meld" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Reconoce la declaración" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Repérez l'annonce" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Riconosci la dichiarazione" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Herken de melding" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Rozpoznaj meldunek" } }
      }
    },
    "tutorial.meld.claim.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Passende Trumpfkarten holen die benannte äußere Mulde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Matching trump cards claim the named outer well." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Las cartas de triunfo adecuadas cobran el pozo exterior indicado." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les atouts correspondants remportent la coupelle extérieure indiquée." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Le carte di briscola adatte conquistano la conca esterna indicata." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Passende troefkaarten winnen de genoemde buitenste kom." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Pasujące atuty zdobywają wskazane zewnętrzne pole." } }
      }
    },
