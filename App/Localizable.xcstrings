    "tutorial.bidding.transfer.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jetzt müssen die anderen mitgehen, erhöhen oder passen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Now the others must call, raise, or fold."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahora los demás deben igualar, subir o pasar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenant, les autres doivent suivre, relancer ou passer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
