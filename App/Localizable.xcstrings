    "help.bonus.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bestimmte Trumpfkarten gewinnen sie sofort." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Certain trump cards win them immediately." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Algunas cartas de triunfo los ganan al instante." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Certaines cartes d'atout les gagnent immédiatement." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Alcune carte di briscola li vincono subito." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Bepaalde troefkaarten winnen ze meteen." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Wybrane atuty wygrywają je od razu." } }
      }
    },
    "help.center.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wer zuerst keine Karten mehr hat, gewinnt sie." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "First to run out of cards wins it." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La gana quien se queda primero sin cartas." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La première personne sans cartes la remporte." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "La vince chi finisce per primo le carte." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Wie het eerst geen kaarten meer heeft, wint het midden." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Wygrywa ją ten, kto pierwszy pozbędzie się kart." } }
      }
    },
    "help.overview.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Drei Wege zu gewinnen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Three ways to win" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tres formas de ganar" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Trois façons de gagner" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Tre modi per vincere" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Drie manieren om te winnen" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Trzy sposoby na wygraną" } }
      }
    },
    "help.poch.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mit gleichen Karten bietest du um ihn." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Bid for it with matching cards." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Pujas por él con cartas iguales." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Tu enchéris dessus avec des cartes identiques." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Fai un'offerta con carte uguali." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Met gelijke kaarten bied je ervoor." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Licytujesz o nią jednakowymi kartami." } }
      }
    },
    "help.visual.bid.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mit zwei gleichen Karten darfst du bieten. Bleiben mehrere, entscheidet die stärkste Gruppe." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Two matching cards let you bid. If several players stay in, the strongest group wins." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Dos cartas iguales te permiten pujar. Si siguen varios, gana el grupo más fuerte." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Deux cartes identiques vous permettent de miser. Si plusieurs restent, le groupe le plus fort gagne." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Due carte uguali ti permettono di puntare. Se restano in più, vince il gruppo più forte." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Met twee gelijke kaarten mag je bieden. Blijven er meer over, dan wint de sterkste groep." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Dwie takie same karty pozwalają licytować. Jeśli zostaje kilka osób, wygrywa najsilniejsza grupa." } }
      }
    },
    "help.visual.meld.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dein Trumpf-König holt den König-Topf - und bleibt in deiner Hand." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your trump King wins the King pot - and stays in your hand." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu Rey de triunfo gana el bote del Rey y se queda en tu mano." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ton Roi d'atout gagne le pot du Roi et reste dans ta main." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il tuo Re di briscola vince il piatto del Re e resta nella tua mano." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je troefheer wint de Herenpot en blijft in je hand." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Twój król atutowy wygrywa pulę króla i zostaje w ręce." } }
      }
    },
    "help.visual.play.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Eine Farbe läuft aufwärts. Wer die Reihe beendet, eröffnet neu." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "One suit runs upwards. Whoever ends the run starts a new one." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Un palo sube en orden. Quien cierra la serie abre una nueva." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Une couleur monte dans l'ordre. Qui termine la suite en ouvre une nouvelle." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Un seme sale in ordine. Chi chiude la sequenza ne apre una nuova." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Eén kleur loopt omhoog. Wie de reeks sluit, opent een nieuwe." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Jeden kolor rośnie po kolei. Kto kończy ciąg, otwiera nowy." } }
      }
    },
