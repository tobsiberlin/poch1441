    "tutorial.coach.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Runde, drei Chancen auf den Topf. Hana zeigt dir jeden Zug direkt am Tisch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Three acts, three clear goals. I stay at the table until you feel the rhythm yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tres actos, tres objetivos claros. Me quedo en la mesa hasta que sientas el ritmo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois actes, trois objectifs clairs. Je reste à table jusqu'à ce que vous trouviez le rythme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tre atti, tre obiettivi chiari. Resto al tavolo finché non senti il ritmo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drie bedrijven, drie heldere doelen. Ik blijf aan tafel tot je het ritme zelf voelt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trzy akty, trzy jasne cele. Zostaję przy stole, aż sam poczujesz rytm."
          }
        }
      }
    },
    "tutorial.completion.all.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Nächstes Mal ohne meine Tipps.“ Der %@-Topf bleibt liegen und wächst. Hana will ihn zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Next time, no hints.” The %@ pot stays on the table and grows. Hana wants it back."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«La próxima, sin pistas». El bote %@ se queda en la mesa y crece. Hana quiere recuperarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« La prochaine fois, sans conseils. » Le pot %@ reste sur la table et grossit. Hana veut le reprendre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«La prossima volta, niente suggerimenti.» Il piatto %@ resta sul tavolo e cresce. Hana lo rivuole."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‘Volgende keer zonder mijn tips.’ De %@-pot blijft liggen en groeit. Hana wil hem terug."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Następnym razem bez moich podpowiedzi.” Pula %@ zostaje na stole i rośnie. Hana chce ją odzyskać."
          }
        }
      }
    },
    "tutorial.completion.all.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nicht schlecht für die erste Runde."
          }
        },
        "en" : {
