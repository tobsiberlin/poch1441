    "firstRun.cinematic.playout.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wer die Reihe schließt, eröffnet neu. Wer zuerst leer ist, nimmt die Mitte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Whoever closes the run leads again. First to empty their hand takes the centre."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quien cierra la serie vuelve a abrir. Quien vacía primero su mano se lleva el centro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qui ferme la suite ouvre la suivante. La première main vide prend le centre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chi chiude la sequenza apre la successiva. Chi svuota per primo la mano prende il centro."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie de reeks sluit, opent opnieuw. Wie als eerste leeg is, pakt het midden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kto zamyka serię, otwiera następną. Kto pierwszy pozbędzie się kart, bierze środek."
          }
        }
      }
    },
