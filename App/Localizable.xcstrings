    "tutorial.meld.hand.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jetzt zeigt die offene Tischkarte, welche Farbe deine Bonus-Töpfe gewinnen kann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Now you reveal trump and look for matching bonus cards."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
