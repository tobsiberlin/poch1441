        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calling costs %d chip and keeps you in the bid. If you fold, your previous stake remains."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Igualar cuesta %d ficha y te mantiene en la puja. Si pasas, tu apuesta anterior se mantiene."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivre coûte %d jeton et vous maintient dans la mise. Si vous passez, votre mise précédente reste."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiamare costa %d fiche e ti mantiene nell'offerta. Se passi, la tua puntata precedente rimane."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meegaan kost %d chip en houdt je in het bod. Bij passen blijft je eerdere inzet liggen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sprawdzenie kosztuje %d żeton i utrzymuje cię w licytacji. Jeśli spasujesz, twój dotychczasowy wkład pozostaje."
          }
        }
      }
    },
