    "tutorial.completion.all.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Du kennst den Rhythmus aus Melden, Pochen und Ausspielen. Im freien Spiel bleiben Hinweise auf Wunsch aktiv." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You know the rhythm of melding, poch and play-out. Guidance can remain active at the open table." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Ya conoces el ritmo de declarar, pochar y jugar. Las ayudas pueden seguir activas en la partida libre." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vous connaissez le rythme des annonces, du poch et du jeu. Les conseils peuvent rester actifs à la table libre." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Conosci il ritmo di dichiarazione, poch e gioco. I suggerimenti possono restare attivi al tavolo libero." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je kent het ritme van melden, pochen en uitspelen. Hints kunnen aan de vrije tafel actief blijven." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Znasz już rytm meldowania, pocha i rozgrywki. Wskazówki mogą pozostać aktywne podczas swobodnej gry." } }
      }
