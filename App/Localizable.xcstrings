    "opponent.tendency.earlyInitiative.summary" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Steigt in offenen Bietrunden vergleichsweise oft zuerst ein." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Often acts first in an unopened bidding round." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Interviene primero con bastante frecuencia cuando nadie ha apostado aún." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Intervient assez souvent en premier quand personne n’a encore misé." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Interviene abbastanza spesso per primo quando nessuno ha ancora puntato." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Neemt vrij vaak als eerste actie wanneer er nog niet is ingezet." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Dość często działa jako pierwszy, gdy nikt jeszcze nie postawił." } }
      }
    },
