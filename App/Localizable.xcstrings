    "tutorial.meld.firstDeal.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Karten siehst nur du. Bei Hana, Noah und Jonas bleiben die Werte verborgen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soon the open table card will show which suit is trump."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pronto la carta abierta sobre la mesa mostrará qué palo es triunfo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bientôt, la carte ouverte sur la table montrera quelle couleur est atout."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
