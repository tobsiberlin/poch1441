    "firstRun.timeSwipe.accessibility.timeline" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zeitlinie von 1441 über Poque bis heute" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Timeline from 1441 through Poque to today" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Línea temporal de 1441 hasta hoy, pasando por Poque" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Frise chronologique de 1441 à aujourd’hui, en passant par le Poque" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Linea del tempo dal 1441 a oggi, passando per il Poque" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Tijdlijn van 1441 via Poque tot vandaag" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Oś czasu od 1441 roku przez Poque do dziś" } }
      }
    },
    "firstRun.timeSwipe.branch.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Poque gilt als möglicher Vorläufer des Pokers. Poch selbst blieb ein eigenes Spiel." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Poque is considered a possible precursor to poker. Poch itself remained a game of its own." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Poque se considera un posible precursor del póker. Poch siguió siendo un juego propio." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le Poque est considéré comme un précurseur possible du poker. Le Poch est resté un jeu à part entière." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il Poque è considerato un possibile precursore del poker. Il Poch è rimasto un gioco a sé." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Poque geldt als een mogelijke voorloper van poker. Poch zelf bleef een eigen spel." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Poque uznaje się za możliwego poprzednika pokera. Sam Poch pozostał odrębną grą." } }
      }
    },
    "firstRun.timeSwipe.branch.eyebrow" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "DIE SPUR ZIEHT WEITER" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "THE TRAIL CONTINUES" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "LA HUELLA CONTINÚA" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "LA PISTE SE POURSUIT" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "LA TRACCIA CONTINUA" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "HET SPOOR LOOPT DOOR" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "ŚLAD PROWADZI DALEJ" } }
      }
    },
    "firstRun.timeSwipe.branch.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Über Poque führt die Spur weiter." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The trail continues through Poque." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La huella continúa a través de Poque." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La piste se poursuit à travers le Poque." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "La traccia continua attraverso il Poque." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Via Poque loopt het spoor verder." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Przez Poque ślad prowadzi dalej." } }
      }
    },
    "firstRun.timeSwipe.hint" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Streiche nach rechts durch die Zeit" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Swipe right through time" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Desliza a la derecha a través del tiempo" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Balaye vers la droite à travers le temps" } },
