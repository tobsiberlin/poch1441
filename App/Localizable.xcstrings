    "phase3.start.detail" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe eine beliebige Karte. Danach folgt automatisch die nächsthöhere Karte derselben Farbe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap any card. Afterwards, the next higher card of the same suit automatically follows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca cualquier carta. Después, la siguiente carta más alta del mismo palo sigue automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur n'importe quelle carte. Ensuite, la carte suivante de la même couleur suit automatiquement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca una carta qualsiasi. Dopodiché, la carta successiva più alta dello stesso seme segue automaticamente."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik op een willekeurige kaart. Daarna volgt automatisch de eerst hogere kaart van dezelfde kleur."
          }
        },
        "pl" : {
