    "tutorial.coach.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drei Akte, drei klare Ziele. Ich bleibe am Tisch, bis du den Rhythmus selbst fühlst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Three acts, three clear goals. I stay at the table until you feel the rhythm yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tres actos, tres objetivos claros. Me quedo en la mesa hasta que sientas el ritmo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois actes, trois objectifs clairs. Je reste à table jusqu'à ce que vous trouviez le rythme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tre atti, tre obiettivi chiari. Resto al tavolo finché non senti il ritmo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drie bedrijven, drie heldere doelen. Ik blijf aan tafel tot je het ritme zelf voelt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trzy akty, trzy jasne cele. Zostaję przy stole, aż sam poczujesz rytm."
          }
        }
      }
    },
    "tutorial.firstTable.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du spielst sofort. Mira erklärt immer nur die eine Entscheidung, die jetzt zählt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You start playing right away. Mira explains only the one decision that matters now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empiezas a jugar de inmediato. Mira explica solo la decisión que importa ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous jouez immédiatement. Mira n'explique que la décision qui compte maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inizi subito a giocare. Mira spiega solo la decisione che conta adesso."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je speelt meteen. Mira legt alleen de beslissing uit die nu telt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Od razu zaczynasz grać. Mira wyjaśnia tylko decyzję, która liczy się teraz."
          }
        }
      }
    },
