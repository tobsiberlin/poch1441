    "phase3.guided.reason.lead.opponent" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ eröffnet mit %@. Jetzt sucht der Tisch die nächsthöhere Karte derselben Farbe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ leads %@. Now the table looks for the next card of the same suit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ abre con %@. Ahora la mesa busca la siguiente carta del mismo palo."
          }
        },
        "fr" : {
