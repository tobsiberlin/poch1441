    "tutorial.meld.release.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast König und Hochzeit gewonnen. Andere Bonus-Töpfe bleiben liegen und wachsen. Jetzt wartet der Poch-Topf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "With at least two identical cards, you may bid. If several remain, the strongest combination decides."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con al menos dos cartas idénticas, puedes pujar. Si quedan varias, la combinación más fuerte decide."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avec au moins deux cartes identiques, vous pouvez miser. S'il en reste plusieurs, la combinaison la plus forte décide."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con almeno due carte identiche, puoi fare un'offerta. Se ne rimangono diverse, la combinazione più forte decide."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met minstens twee identieke kaarten mag je bieden. Blijven er meerdere over, dan beslist de sterkste combinatie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Z przynajmniej dwiema identycznymi kartami możesz licytować. Jeśli pozostanie ich kilka, decyduje najsilniejsza kombinacja."
          }
        }
      }
    },
