    "phase3.guided.reason.follow.opponent" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ legt %@, weil sie direkt auf %@ folgt und dieselbe Farbe hat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ plays %@ because it follows %@ directly in the same suit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ juega %@ porque sigue directamente a %@ y es del mismo palo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ joue %@ car elle suit directement %@ dans la même couleur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ gioca %@ perché segue direttamente %@ ed è dello stesso seme."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ speelt %@ omdat die direct op %@ volgt en dezelfde kleur heeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ zagrywa %@, bo następuje bezpośrednio po %@ i ma ten sam kolor."
          }
        }
      }
    },
