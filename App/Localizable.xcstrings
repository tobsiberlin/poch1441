    "tutorial.meld.drag.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder legt einen Chip in jeden Topf. So gibt es gleich etwas zu gewinnen. Zieh deinen ersten Chip in die Mitte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Everyone puts one chip into each pot. That gives you something to win right away. Drag your first chip to the centre."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada uno pone una ficha en cada bote. Así hay algo que ganar desde el principio. Arrastra tu primera ficha al centro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chacun met un jeton dans chaque pot. Il y a donc tout de suite quelque chose à gagner. Fais glisser ton premier jeton au centre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ognuno mette una fiche in ogni piatto. Così c'è subito qualcosa da vincere. Trascina la tua prima fiche al centro."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iedereen legt een chip in elke pot. Zo valt er meteen iets te winnen. Sleep je eerste chip naar het midden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Każdy wkłada żeton do każdej puli. Od razu jest więc o co grać. Przeciągnij swój pierwszy żeton na środek."
          }
        }
      }
    },
