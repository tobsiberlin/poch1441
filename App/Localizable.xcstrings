        }
      }
    },
    "tutorial.firstTable.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du spielst sofort. Hana erklärt immer nur die eine Entscheidung, die jetzt zählt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You start playing right away. Hana explains only the one decision that matters now."
          }
