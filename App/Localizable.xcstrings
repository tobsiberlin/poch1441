    "firstRun.intro.body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "In der Mitte wartet dein erster Gewinn. Hana zeigt dir immer nur den nächsten Zug." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your first prize is waiting in the centre. Hana shows you only the next move." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu primer premio te espera en el centro. Hana solo te muestra el siguiente movimiento." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Votre premier gain vous attend au centre. Hana vous montre uniquement le prochain coup." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "La tua prima vincita ti aspetta al centro. Hana ti mostra solo la prossima mossa." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Je eerste winst wacht in het midden. Hana toont alleen de volgende zet." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Pierwsza wygrana czeka na środku. Hana pokazuje tylko następny ruch." } }
      }
    },
    "firstRun.intro.board.accessibility" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Poch-Scheibe mit acht Gewinnfeldern und Mitte" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Poch disc with eight prize wells and a centre" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Disco de Poch con ocho casillas de premio y centro" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Disque de Poch avec huit coupelles de gain et un centre" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Disco Poch con otto vaschette premio e centro" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Poch-schijf met acht winstvakjes en een midden" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Dysk Poch z ośmioma polami wygranej i środkiem" } }
