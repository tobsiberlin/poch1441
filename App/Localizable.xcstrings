    "tutorial.bidding.stake.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Einsatz entscheidet, wer dabeibleibt - nicht, wer gewinnt. Setze vorsichtig 1 Chip oder mache mit 2 Chips Druck."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your chip is your bid. If you lose the Poch, it's gone. One chip keeps your risk low."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu ficha es tu puja. Si pierdes el Poch, se ha ido. Una ficha mantiene tu riesgo bajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre jeton est votre mise. Si vous perdez le Poch, il est parti. Un jeton maintient votre risque faible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua fiche è la tua offerta. Se perdi il Poch, è andata. Una fiche mantiene basso il tuo rischio."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je chip is je bod. Verlies je de Poch, dan is hij weg. Eén chip houdt je risico klein."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twój żeton to twoja stawka. Jeśli przegrasz Poch, żeton przepada. Jeden żeton minimalizuje ryzyko."
          }
        }
      }
    },
